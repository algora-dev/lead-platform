generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

enum UserRole {
  ADMIN
  MEMBER
}

enum ProfileVersionStatus {
  DRAFT
  NEEDS_STRUCTURING
  READY
}

model Tenant {
  id          Int      @id @default(autoincrement())
  createdAt   DateTime @default(now())
  name        String   @unique
  slug        String   @unique
  branding    Json?
  features    Json?
  users       User[]
  companies   Company[]
  batches     Batch[]
  scanRuns    ScanRun[]
  scanProfiles ScanProfile[]
  filterPresets FilterPreset[]
  leadsParents LeadsParent[]
  // V2 relations
  productProfiles   ProductProfile[]
  customerProfiles  CustomerProfile[]
  discoveryStrategies DiscoveryStrategy[]
  scanLibraries     ScanLibrary[]
  discoveryScans    DiscoveryScan[]
}

model User {
  id           Int       @id @default(autoincrement())
  createdAt    DateTime  @default(now())
  email        String    @unique
  passwordHash String
  name         String?
  role         UserRole  @default(MEMBER)
  active       Boolean   @default(true)
  tenantId     Int
  tenant       Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

enum CompanyStatus {
  NEW
  REVIEWING
  CONTACTED
  FOLLOW_UP
  MEETING
  ASSESSMENT
  WON
  PASSED
  NO_RESPONSE
  NOT_INTERESTED
}

model Company {
  id                    Int           @id @default(autoincrement())
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt
  tenantId              Int
  tenant                Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name                  String
  normalizedName        String
  country               String?
  website               String?
  phone                 String?
  email                 String?
  contactSourceUrl      String?
  employeeCount         Int?
  employeeRange         String?
  industry              String?
  location              String?
  activeJobCount        Int           @default(0)
  totalJobCount         Int           @default(0)
  estimatedSalarySpend  Int           @default(0)
  opportunityScore      Int           @default(0)
  scoreReason           String?
  recurringTasks        String?
  opportunitySummary    String?
  status                CompanyStatus @default(NEW)
  notes                 String?
  discarded             Boolean       @default(false)
  // V2 fields
  domain                String?
  materialisedFacts     Json?
  firstSeenAt           DateTime      @default(now())
  lastSeenAt            DateTime      @default(now())
  jobs                  JobAdvert[]
  batches               Batch[]
  contactLogs           ContactLog[]
  scanLeadFlags         ScanLeadFlag[]
  // V2 relations
  scanCandidates        ScanCandidate[]
  companyAliases        CompanyAlias[]
  providerIdentities    CompanyProviderIdentity[]
  evidenceItems         EvidenceItem[]
  evidenceClaims        EvidenceClaim[]
  assessmentSnapshots   AssessmentSnapshot[]
  @@unique([tenantId, normalizedName, country])
}

model JobAdvert {
  id                Int      @id @default(autoincrement())
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  companyId         Int
  company           Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  title             String
  country           String?
  location          String?
  salaryText        String?
  annualSalaryHigh  Int?
  source            String
  sourceUrl         String   @unique
  canonicalUrl      String   @unique
  discoveryQuery    String?
  description       String?
  taskSignals       String?
  advertScore       Int      @default(0)
  firstSeenAt       DateTime @default(now())
  lastSeenAt        DateTime @default(now())
  isActive          Boolean  @default(true)
}

model Batch {
  id          Int       @id @default(autoincrement())
  tenantId    Int
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  profileId   Int?
  profile     ScanProfile? @relation(fields: [profileId], references: [id], onDelete: SetNull)
  leadsParentId Int?
  leadsParent   LeadsParent? @relation(fields: [leadsParentId], references: [id], onDelete: SetNull)
  name        String
  scanArea    String?
  createdBy   String?
  originalScanDate DateTime @default(now())
  lastScanDate DateTime?
  createdAt   DateTime  @default(now())
  archivedAt  DateTime?
  notes       String?
  companies   Company[]
  scanRuns    ScanRun[]
  scanLeadFlags ScanLeadFlag[]
}

model ScanProfile {
  id            Int       @id @default(autoincrement())
  tenantId      Int
  tenant        Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name          String
  slug          String
  description   String?
  isActive      Boolean   @default(true)
  config        Json
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  scanRuns      ScanRun[]
  batches       Batch[]
  @@unique([tenantId, slug])
}

model ScanRun {
  id                 Int       @id @default(autoincrement())
  tenantId           Int
  tenant             Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  profileId          Int?
  profile            ScanProfile? @relation(fields: [profileId], references: [id], onDelete: SetNull)
  batchId            Int?
  batch              Batch?     @relation(fields: [batchId], references: [id], onDelete: SetNull)
  source             String
  scanArea           String?
  startedAt          DateTime  @default(now())
  completedAt        DateTime?
  status             String    @default("RUNNING")
  deepOffset         Int       @default(1)
  searchRequests     Int       @default(0)
  resultsFound       Int       @default(0)
  pagesFetched       Int       @default(0)
  duplicateAdverts   Int       @default(0)
  advertsSaved       Int       @default(0)
  companiesCreated   Int       @default(0)
  companiesUpdated   Int       @default(0)
  contactsFound      Int       @default(0)
  errors             Int       @default(0)
  message            String?
  isRescan           Boolean   @default(false)
  newCompanies       Int       @default(0)
  updatedCompanies   Int       @default(0)
}

model ContactLog {
  id          Int       @id @default(autoincrement())
  createdAt   DateTime  @default(now())
  companyId   Int
  company     Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  type        String    @default("note")
  content     String
  authorName  String?
  oldStatus   String?
  newStatus   String?
}

model FilterPreset {
  id          Int       @id @default(autoincrement())
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  tenantId    Int
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name        String
  config      Json
  @@unique([tenantId, name])
}

model LeadsParent {
  id          Int       @id @default(autoincrement())
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  tenantId    Int
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name        String
  description String?
  createdBy   String?
  batches     Batch[]
  @@unique([tenantId, name])
}

model ScanLeadFlag {
  id          Int       @id @default(autoincrement())
  createdAt   DateTime  @default(now())
  companyId   Int
  company     Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  batchId     Int
  batch       Batch     @relation(fields: [batchId], references: [id], onDelete: Cascade)
  flagType    String    @default("NEW")
  previousScore Int?
  newScore    Int?
  acknowledged Boolean  @default(false)
  @@unique([companyId, batchId, flagType])
}

// ============================================================
// V2 — Additive tables (do not modify V1 tables)
// ============================================================

// --- Product & Customer Profiles ---

model ProductProfile {
  id          Int       @id @default(autoincrement())
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  tenantId    Int
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name        String
  description String?
  archivedAt  DateTime?
  versions    ProductProfileVersion[]
  @@unique([tenantId, name])
}

model ProductProfileVersion {
  id              Int       @id @default(autoincrement())
  createdAt       DateTime  @default(now())
  profileId       Int
  profile         ProductProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  versionNumber   Int
  status          ProfileVersionStatus @default(DRAFT)
  // Structured fields from AI or manual entry
  problemsSolved  String[]
  outcomes        String[]
  industries      String[]
  keywords        String[]
  technologies    String[]
  companySizeMin  Int?
  companySizeMax  Int?
  pricingLevel    String?
  exclusions      String[]
  notes           String?
  // Original user input preserved
  rawInput        Json
  // AI processing metadata
  aiModel         String?
  aiPromptVersion String?
  approvedBy      String?
  approvedAt      DateTime?
  @@unique([profileId, versionNumber])
}

model CustomerProfile {
  id          Int       @id @default(autoincrement())
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  tenantId    Int
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name        String
  description String?
  archivedAt  DateTime?
  versions    CustomerProfileVersion[]
  @@unique([tenantId, name])
}

model CustomerProfileVersion {
  id                  Int       @id @default(autoincrement())
  createdAt           DateTime  @default(now())
  profileId           Int
  profile             CustomerProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  versionNumber       Int
  status              ProfileVersionStatus @default(DRAFT)
  industries          String[]
  locations           String[]
  employeeCountMin    Int?
  employeeCountMax    Int?
  revenueMin          Int?
  revenueMax          Int?
  technologies        String[]
  operationalCharacteristics String[]
  buyingSignals      String[]
  hiringSignals      String[]
  decisionMakers     String[]
  exclusions         String[]
  notes              String?
  rawInput            Json
  aiModel             String?
  aiPromptVersion     String?
  approvedBy          String?
  approvedAt          DateTime?
  @@unique([profileId, versionNumber])
}

// --- Discovery Strategy ---

model DiscoveryStrategy {
  id              Int       @id @default(autoincrement())
  createdAt       DateTime  @default(now())
  tenantId        Int
  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  // Linked profile versions (immutable snapshot)
  productProfileVersionIds  Int[]
  customerProfileVersionIds Int[]
  // Compiled strategy data
  queries         Json      // search queries
  keywords        String[]
  inclusionFilters Json
  exclusionFilters String[]
  evidencePriorities String[]
  enrichmentPriorities String[]
  // Geography
  country         String
  stateProvince   String?
  county          String?
  city            String?
  radiusKm        Int?
  // Compiler version (for invalidation when compiler changes)
  compilerVersion  String    @default("v1")
  // Scoring policy
  scoringPolicyVersion String
  scoringConfig   Json
  // AI metadata
  aiModel         String?
  aiPromptVersion String?
  // Status
  approved        Boolean   @default(false)
  approvedBy      String?
  approvedAt      DateTime?
  scans           DiscoveryScan[]

  // v3 fields
  assessments          StrategyAssessment[] @relation("StrategyAssessmentHistory")
  currentAssessmentId  Int? @unique
  currentAssessment    StrategyAssessment? @relation("CurrentStrategyAssessment", fields: [currentAssessmentId], references: [id], onDelete: SetNull)
  preparationStatus    StrategyPreparationStatus @default(ASSESSING)
  assessmentError      String?
  finalKeywords        Json?
  finalQueries         String[] @default([])
  scoreThreshold       Int @default(0)
}

// --- Scan Library ---

model ScanLibrary {
  id          Int       @id @default(autoincrement())
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  tenantId    Int
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name        String
  description String?
  archivedAt  DateTime?
  scans       DiscoveryScan[]
  @@unique([tenantId, name])
}

// --- Discovery Scan ---

enum DiscoveryScanStatus {
  PENDING
  DISCOVERING
  EVIDENCE_GATHERING
  EVIDENCE_COMPLETE
  SCORING
  COMPLETED
  FAILED
  CANCELLED
}

model DiscoveryScan {
  id              Int       @id @default(autoincrement())
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  tenantId        Int
  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  libraryId       Int?
  library         ScanLibrary? @relation(fields: [libraryId], references: [id], onDelete: SetNull)
  strategyId      Int
  strategy        DiscoveryStrategy @relation(fields: [strategyId], references: [id], onDelete: Restrict)
  parentScanId    Int?      // for rescans
  name            String
  status          DiscoveryScanStatus @default(PENDING)
  // Progress
  progress        Int       @default(0)  // 0-100
  // Modes
  discoverNewOnly Boolean   @default(false)
  recheckEvidence Boolean   @default(false)
  rerunAll        Boolean   @default(false)
  // Counts
  candidateCount  Int       @default(0)
  newCompanies    Int       @default(0)
  updatedCompanies Int      @default(0)
  // Cost tracking
  totalCostUnits  Int       @default(0)
  // Timestamps
  startedAt       DateTime?
  completedAt     DateTime?
  errorMessage    String?
  // Relations
  candidates      ScanCandidate[]
  providerRuns    ProviderRun[]
  assessments     AssessmentSnapshot[]
}

// --- Scan Candidate ---

model ScanCandidate {
  id              Int       @id @default(autoincrement())
  scanId          Int
  scan            DiscoveryScan @relation(fields: [scanId], references: [id], onDelete: Cascade)
  companyId       Int
  company         Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  // Discovery provenance
  discoveryProvider String
  discoveryQuery    String?
  discoveryUrl      String?
  // Profile Score (frozen at discovery time)
  profileScore      Int       @default(0)
  profileScoreBreakdown Json?
  // Processing state
  evidenceGathered  Boolean   @default(false)
  assessmentDone    Boolean   @default(false)
  // v3 fields
  discoveryData        Json?
  keywordMatches       Json?
  selectedForEvidence  Boolean @default(false)
  @@unique([scanId, companyId])
}

// --- Company Identity ---

model CompanyAlias {
  id          Int       @id @default(autoincrement())
  companyId   Int
  company     Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  alias       String
  source      String?
  createdAt   DateTime  @default(now())
  @@unique([companyId, alias])
}

model CompanyProviderIdentity {
  id              Int       @id @default(autoincrement())
  companyId       Int
  company         Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  provider        String    // e.g. 'apollo', 'companies_house'
  providerId     String
  rawPayload      Json?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  @@unique([provider, providerId])
}

// --- Evidence ---

enum EvidenceType {
  JOB_ADVERT
  COMPANY_WEBSITE
  APOLLO_DATA
  TECH_STACK
  CONTACT_INFO
  NEWS_ARTICLE
  FUNDING_EVENT
  TENDER
  REVIEW
  SOCIAL_PROFILE
  OTHER
}

model EvidenceItem {
  id              Int       @id @default(autoincrement())
  createdAt       DateTime  @default(now())
  companyId       Int
  company         Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  scanId          Int?      // link to scan that discovered it
  providerRunId   Int?
  evidenceType    EvidenceType
  sourceUrl       String?
  sourceDomain    String?
  // Content
  rawPayload      Json?
  contentHash     String?   // for deduplication
  normalisedPayload Json?
  // Quality
  reliability     Int       @default(50)  // 0-100
  freshnessDays   Int?      // age of source data
  observedAt      DateTime?
  collectedAt     DateTime  @default(now())
  claims          EvidenceClaim[]
  @@unique([companyId, evidenceType, sourceUrl])
}

enum ClaimType {
  LOCATION
  EMPLOYEE_COUNT
  TECHNOLOGY
  JOB_ADVERT
  OPERATIONAL_ACTIVITY
  FUNDING_EVENT
  CONTACT_ROLE
  REPEATED_SIGNAL
  INDUSTRY
  REVENUE
}

model EvidenceClaim {
  id              Int       @id @default(autoincrement())
  createdAt       DateTime  @default(now())
  evidenceItemId  Int
  evidenceItem    EvidenceItem @relation(fields: [evidenceItemId], references: [id], onDelete: Cascade)
  companyId       Int
  company         Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  claimType       ClaimType
  claimValue      String
  claimData       Json?
  // Support/contradict
  supports        Boolean   @default(true)
  contradictions  String[]
  @@unique([evidenceItemId, claimType, claimValue])
}

// --- Provider Run ---

model ProviderRun {
  id              Int       @id @default(autoincrement())
  createdAt       DateTime  @default(now())
  scanId          Int
  scan            DiscoveryScan @relation(fields: [scanId], references: [id], onDelete: Cascade)
  provider        String
  providerVersion String?
  role            String    // 'discovery' or 'evidence'
  status          String    @default("PENDING")
  attempts        Int       @default(0)
  startedAt       DateTime?
  completedAt     DateTime?
  requestCount    Int       @default(0)
  resultCount     Int       @default(0)
  costUnits       Int       @default(0)
  errorMessage    String?
}

// --- Assessment Snapshot ---

model AssessmentSnapshot {
  id              Int       @id @default(autoincrement())
  createdAt       DateTime  @default(now())
  scanId          Int
  scan            DiscoveryScan @relation(fields: [scanId], references: [id], onDelete: Cascade)
  companyId       Int
  company         Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  strategyId      Int
  // Scores
  profileScore    Int       @default(0)
  confidenceScore Int       @default(0)
  combinedScore   Int       @default(0)
  // Breakdowns
  profileBreakdown    Json?
  confidenceBreakdown Json?
  // Policy
  scoringPolicyVersion String
  combinedPolicyVersion String
  // Explanation
  aiSummary          String?
  outreachRationale  String?
  unknowns           String[]
  contradictions     String[]
  // Evidence links
  evidenceItemIds    Int[]
  // Prior comparison
  priorSnapshotId    Int?
  scoreChange        Int?   // combined score delta vs prior
}

// ============================================================
// v3 Strategy Assessment System
// ============================================================

enum StrategyAssessmentStatus {
  PENDING
  CONFIRMED
  SUPERSEDED
}

enum StrategyPreparationStatus {
  ASSESSING
  AWAITING_CONFIRMATION
  READY
  FAILED
}

model StrategyAssessment {
  id                   Int      @id @default(autoincrement())
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  strategyId           Int
  strategy             DiscoveryStrategy @relation("StrategyAssessmentHistory", fields: [strategyId], references: [id], onDelete: Cascade)

  // AI Assessment Output
  understandingSummary String
  scoringKeywords      Json     // [{ keyword, points, rationale }]
  broadQueries         String[] @default([])

  // AI metadata
  aiModel              String?
  aiPromptVersion      String?

  // User Confirmation State
  status               StrategyAssessmentStatus @default(PENDING)
  userClarification    String?
  userEditedKeywords   Json?
  confirmedBy          String?
  confirmedAt          DateTime?

  // Rebuild chain
  parentAssessmentId   Int?
  parentAssessment     StrategyAssessment? @relation("AssessmentRebuild", fields: [parentAssessmentId], references: [id], onDelete: SetNull)
  rebuilds             StrategyAssessment[] @relation("AssessmentRebuild")
  currentForStrategy   DiscoveryStrategy? @relation("CurrentStrategyAssessment")

  @@index([strategyId, createdAt])
}
