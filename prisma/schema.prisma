generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  MEMBER
}

model Tenant {
  id          Int      @id @default(autoincrement())
  createdAt   DateTime @default(now())
  name        String   @unique
  slug        String   @unique
  branding    Json?
  features    Json?
  users       User[]
  companies   Company[]
  batches     Batch[]
  scanRuns    ScanRun[]
  scanProfiles ScanProfile[]
  filterPresets FilterPreset[]
  leadsParents LeadsParent[]
}

model User {
  id           Int       @id @default(autoincrement())
  createdAt    DateTime  @default(now())
  email        String    @unique
  passwordHash String
  name         String?
  role         UserRole  @default(MEMBER)
  active       Boolean   @default(true)
  tenantId     Int
  tenant       Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

enum CompanyStatus {
  NEW
  REVIEWING
  CONTACTED
  FOLLOW_UP
  MEETING
  ASSESSMENT
  WON
  PASSED
  NO_RESPONSE
  NOT_INTERESTED
}

model Company {
  id                    Int           @id @default(autoincrement())
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt
  tenantId              Int
  tenant                Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name                  String
  normalizedName        String
  country               String?
  website               String?
  phone                 String?
  email                 String?
  contactSourceUrl      String?
  employeeCount         Int?
  employeeRange         String?
  industry              String?
  location              String?
  activeJobCount        Int           @default(0)
  totalJobCount         Int           @default(0)
  estimatedSalarySpend  Int           @default(0)
  opportunityScore      Int           @default(0)
  scoreReason           String?
  recurringTasks        String?
  opportunitySummary    String?
  status                CompanyStatus @default(NEW)
  notes                 String?
  discarded             Boolean       @default(false)
  firstSeenAt           DateTime      @default(now())
  lastSeenAt            DateTime      @default(now())
  jobs                  JobAdvert[]
  batches               Batch[]
  contactLogs           ContactLog[]
  scanLeadFlags         ScanLeadFlag[]
  @@unique([tenantId, normalizedName, country])
}

model JobAdvert {
  id                Int      @id @default(autoincrement())
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  companyId         Int
  company           Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  title             String
  country           String?
  location          String?
  salaryText        String?
  annualSalaryHigh  Int?
  source            String
  sourceUrl         String   @unique
  canonicalUrl      String   @unique
  discoveryQuery    String?
  description       String?
  taskSignals       String?
  advertScore       Int      @default(0)
  firstSeenAt       DateTime @default(now())
  lastSeenAt        DateTime @default(now())
  isActive          Boolean  @default(true)
}

model Batch {
  id          Int       @id @default(autoincrement())
  tenantId    Int
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  profileId   Int?
  profile     ScanProfile? @relation(fields: [profileId], references: [id], onDelete: SetNull)
  leadsParentId Int?
  leadsParent   LeadsParent? @relation(fields: [leadsParentId], references: [id], onDelete: SetNull)
  name        String
  scanArea    String?
  createdBy   String?
  originalScanDate DateTime @default(now())
  lastScanDate DateTime?
  createdAt   DateTime  @default(now())
  archivedAt  DateTime?
  notes       String?
  companies   Company[]
  scanRuns    ScanRun[]
  scanLeadFlags ScanLeadFlag[]
}

model ScanProfile {
  id            Int       @id @default(autoincrement())
  tenantId      Int
  tenant        Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name          String
  slug          String
  description   String?
  isActive      Boolean   @default(true)
  config        Json
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  scanRuns      ScanRun[]
  batches       Batch[]
  @@unique([tenantId, slug])
}

model ScanRun {
  id                 Int       @id @default(autoincrement())
  tenantId           Int
  tenant             Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  profileId          Int?
  profile            ScanProfile? @relation(fields: [profileId], references: [id], onDelete: SetNull)
  batchId            Int?
  batch              Batch?     @relation(fields: [batchId], references: [id], onDelete: SetNull)
  source             String
  scanArea           String?
  startedAt          DateTime  @default(now())
  completedAt        DateTime?
  status             String    @default("RUNNING")
  deepOffset         Int       @default(1)
  searchRequests     Int       @default(0)
  resultsFound       Int       @default(0)
  pagesFetched       Int       @default(0)
  duplicateAdverts   Int       @default(0)
  advertsSaved       Int       @default(0)
  companiesCreated   Int       @default(0)
  companiesUpdated   Int       @default(0)
  contactsFound      Int       @default(0)
  errors             Int       @default(0)
  message            String?
  isRescan           Boolean   @default(false)
  newCompanies       Int       @default(0)
  updatedCompanies   Int       @default(0)
}

model ContactLog {
  id          Int       @id @default(autoincrement())
  createdAt   DateTime  @default(now())
  companyId   Int
  company     Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  type        String    @default("note")
  content     String
  authorName  String?
  oldStatus   String?
  newStatus   String?
}

model FilterPreset {
  id          Int       @id @default(autoincrement())
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  tenantId    Int
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name        String
  config      Json
  @@unique([tenantId, name])
}

model LeadsParent {
  id          Int       @id @default(autoincrement())
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  tenantId    Int
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name        String
  description String?
  createdBy   String?
  batches     Batch[]
  @@unique([tenantId, name])
}

model ScanLeadFlag {
  id          Int       @id @default(autoincrement())
  createdAt   DateTime  @default(now())
  companyId   Int
  company     Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  batchId     Int
  batch       Batch     @relation(fields: [batchId], references: [id], onDelete: Cascade)
  flagType    String    @default("NEW")
  previousScore Int?
  newScore    Int?
  acknowledged Boolean  @default(false)
  @@unique([companyId, batchId, flagType])
}
